# Supabase target project
# Ref: cqqkrheyjtdysclkeuxn
NEXT_PUBLIC_SUPABASE_URL=https://cqqkrheyjtdysclkeuxn.supabase.co
SUPABASE_URL=https://cqqkrheyjtdysclkeuxn.supabase.co

# Fill from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Nexius Control onboarding integration
# Either set NEXIUS_CONTROL_ONBOARDING_URL directly, or set NEXIUS_CONTROL_BASE_URL.
NEXIUS_CONTROL_ONBOARDING_URL=
NEXIUS_CONTROL_BASE_URL=
NEXIUS_CONTROL_ONBOARDING_TOKEN=
NEXIUS_CONTROL_ALLOW_SELF_SIGNED_TLS=false
NEXIUS_CONTROL_ONBOARDING_TIMEOUT_MS=60000

# Airwallex webhook validation + default package fallback
AIRWALLEX_WEBHOOK_SECRET=
DEFAULT_PACKAGE_ID=runtime_plus_ui_supabase
DEFAULT_PACKAGE_VERSION=2026.04.0

# Fulfillment worker/admin controls
FULFILLMENT_WORKER_TOKEN=
FULFILLMENT_ADMIN_USER_IDS=
